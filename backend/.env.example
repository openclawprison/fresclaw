PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@ep-xxx.region.neon.tech/neondb?sslmode=require
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=fresclaw
R2_PUBLIC_URL=https://your-bucket.r2.dev
JWT_SECRET=generate_with_openssl_rand_hex_32
FRONTEND_URL=https://fresclaw.com
# Backend will be at api.fresclaw.com — set custom domain in Render
LEMON_WEBHOOK_SECRET=your_lemon_webhook_signing_secret
LEMON_STORE_ID=your_lemon_store_id
